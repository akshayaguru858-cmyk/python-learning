import csv
data=[["Name","Age","City"]
["Akshaya","19","Chennai"]
["Reshma","19","Coimbatore"]
["Divya","19","Madurai"]
]
with open("students.csv","w", newline="" ) as file:
    writer=csv.writer(file)
    for row in data:
        writer.writerow(row)
print("CSV file created!")
        
